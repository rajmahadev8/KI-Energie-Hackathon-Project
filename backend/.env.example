# Copy to .env and fill in. NEVER commit .env.
# OpenRouter API key (also available in the user's ~/.bashrc as OPENROUTER_API_KEY)
OPENROUTER_API_KEY=

# OpenRouter (OpenAI-compatible) endpoint
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models — cost-optimized Chinese models (override if desired)
TEXT_MODEL=deepseek/deepseek-v4-flash
VISION_MODEL=qwen/qwen3-vl-32b-instruct

# CORS: comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Use cached demo answers if the LLM call fails (true/false)
ENABLE_DEMO_CACHE=true
